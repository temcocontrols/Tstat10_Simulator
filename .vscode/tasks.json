{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Tstat10: dev server (static + console pipe)",
      "type": "shell",
      "command": "npm run start",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "OPEN_BROWSER": "0"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "tstat10-dev",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "listening on http://127\\.0\\.0\\.1:"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    }
  ]
}
