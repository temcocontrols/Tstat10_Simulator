{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tstat10.local/schemas/tstat10-screen.schema.json",
  "title": "Tstat10 simulator screen JSON",
  "description": "Authoring payload for Tstat10.html / network-settings-renderer. At codegen, `page` enum is merged from screens-registry.json (+ additionalPageIdsForSchema); widget `type` enum is merged from schemas/widget-types.json.",
  "type": "object",
  "required": ["page", "widgets"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "string" },
    "page": {
      "type": "string"
    },
    "styles": { "type": "object", "additionalProperties": true },
    "layout": { "type": "object", "additionalProperties": true },
    "widgets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string"
          }
        }
      }
    },
    "canvasProfile": { "type": "object", "additionalProperties": true },
    "colorProfile": { "type": "object", "additionalProperties": true },
    "compatibility": { "type": "object", "additionalProperties": true }
  }
}
